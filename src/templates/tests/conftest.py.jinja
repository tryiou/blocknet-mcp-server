# Helper functions
def resolve_params(template: dict, ctx: TestContext) -> dict:
    """Replace placeholders in parameter template with runtime values"""
    now = int(time.time())
    mapping = {
        "MAKER": ctx.maker,
        "TAKER": ctx.taker,
        "BLOCKCHAIN": ctx.block_chain,
        "FIRST_ORDER_ID": ctx.order_ids[0] if ctx.order_ids else None,
        "HEIGHT": str(ctx.block_height) if ctx.block_height else None,
        "HASH": ctx.block_hash,
        "EPOCH_NOW": now,
        "EPOCH_1D_AGO": now - 86400,
        "DUMMY": "0" * 64,
        "TX_HEX": ctx.tx_hex,
        "LAST_UUID": ctx.last_uuid,
    }
    return {k: mapping.get(v, v) for k, v in template.items()}


async def safe_call(rpc_client, method: str, params: list, expected_type: str):
    """Call RPC method and validate response type"""
    try:
        result = await rpc_client.call(method, params)
        if result is None:
            return False, None, "Empty response (None)"
        if expected_type == "dict" and not isinstance(result, dict):
            return False, result, f"Expected dict, got {type(result).__name__}"
        if expected_type == "list" and not isinstance(result, list):
            return False, result, f"Expected list, got {type(result).__name__}"
        return True, result, None
    except Exception as e:
        return False, None, str(e)


